{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "spring": {
    "application": {
      "name": "PricingService"
    }
  },

  "eureka": {
    "client": {
      "shouldRegisterWithEureka": true,
      "serviceUrl": "http://localhost:8761/eureka/",
      "validateCertificates": false
    },
    "instance": {
      "preferIpAddress": true
    }
  }
}